# Header
# The header defines the base operating system
Bootstrap: docker
From: ubuntu:22.04

# Add some information to the container
%labels
    Author Chandrashekar CR
    Version v1.0.0
    Description "eDNA metageomics application"

%environment
    export LC_ALL=C
    export DEBIAN_FRONTEND=noninteractive
    export PATH="/usr/local/bin:$PATH"

%files
    # Copy files from host to container
    Makefile /opt/binp51/
    pyproject.toml /opt/binp51/
    requirements.txt /opt/binp51/
    src/ /opt/binp51/
    workflow/ /opt/binp51/
    config/ /opt/binp51/
    profiles/ /opt/binp51/
    tests/ /opt/binp51/
    README.md /opt/binp51/
    environment.yml /opt/binp51/

%post
    # Prevent interactive prompts during apt installation
    export DEBIAN_FRONTEND=noninteractive

    # Update system and install basic build tools, python, and apptainer dependencies
    apt-get update && apt-get install -y \
        software-properties-common \
        wget \
        curl \
        git \
        build-essential \
        python3.11 \
        python3.11-venv \
        python3-pip \
        tar \
        gzip \
        make

    # Apptainer is not in the default Ubuntu 22.04 repositories, so we add its PPA
    add-apt-repository -y ppa:apptainer/ppa
    apt-get update
    apt-get install -y apptainer

    # Set python3 to point to python3.11
    update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1
    update-alternatives --install /usr/bin/python python /usr/bin/python3.11 1

    # Upgrade pip globally
    python -m pip install --upgrade pip

    # Create project directory
    mkdir -p /opt/binp51

    cd /opt/binp51

    # Create the bin directory 
    mkdir -p bin

    # Creating base python environemnt
    echo "Creating a base python environment"
    make venv

    # Run the make commands to set up the environemnts
    echo "Creating environemnts and installing dependencies"
    make venv-all

    echo "Downloading bioinformatics tools..."
    make download

    echo "Container build complete!"

%runscript
    cd /opt/binp51
    # Activate the full environment by default
    . .venv-all/bin/activate
    exec "$@"

%test
    cd /opt/binp51
    . .venv-all/bin/activate
    echo "Testing Python installation..."
    python --version
    echo "Testing pytest..."
    pytest --version
    echo "Testing snakemake..."
    snakemake --version
    echo "Checking tools in bin directory..."
    ls -lh bin/
    echo "All tests passed!"