# Step 9 - Kraken2
rule kraken:
    input:
        r1 = lambda w: os.path.join(RESULTS_DIR,"05_error_correction",f"{w.sample}_R1_corrected.fastq.gz"),
        r2 = lambda w: os.path.join(RESULTS_DIR,"05_error_correction",f"{w.sample}_R2_corrected.fastq.gz")

    output:
        kraken = os.path.join(RESULTS_DIR, "08_kraken2","{sample}","kraken.tsv"),
        kraken_report = os.path.join(RESULTS_DIR, "08_kraken2", "{sample}","kraken_report.tsv")
    
    log:
        os.path.join(RESULTS_DIR,"08_kraken2","{sample}.log")

    resources:
        mem_mb = config['resources']['kraken2']['mem_mb'], # 460G: core-nt DB 310G + index/buffers/OS; aurora routes to ca19-ca22 (768G) only at this size
        runtime = config['resources']['kraken2']['runtime_min'],
        slurm_partition = select_best_partition  # fills: aurora(4) -> gpua40(6) -> gpua40i(6)

    threads:
        config['resources']['kraken2']['threads']

    params:
        out_dir = os.path.join(RESULTS_DIR,"08_kraken2","{sample}"),
        database = KRAKEN2_DB,
        kraken2 = TOOLS['kraken2']

    shell:
        """
        mkdir -p {params.out_dir}

        apptainer exec \
            --bind {RESULTS_DIR}:{RESULTS_DIR} \
            --bind /lunarc/nobackup/projects/snic2019-34-3/:/lunarc/nobackup/projects/snic2019-34-3/ \
            {params.kraken2} kraken2 \
                --db {params.database} \
                --threads {threads} \
                --report {output.kraken_report} \
                --output {output.kraken} \
                --paired {input.r1} {input.r2} > {log} 2>&1
        """

# Step 10: Bracken
rule bracken:
    input:
        kraken_report = os.path.join(RESULTS_DIR,"08_kraken2","{sample}","kraken_report.tsv")

    output:
        bracken_report = os.path.join(RESULTS_DIR,"09_bracken","{sample}","{rank}.tsv")
    log:
        bracken_log = os.path.join(RESULTS_DIR,"09_bracken","{sample}.{rank}.out")

    resources:
        mem_mb = config['resources']['bracken']['mem_mb'],
        runtime = config['resources']['bracken']['runtime_min']

    params:
        bracken = TOOLS['bracken'],
        database = BRACKEN_DB,
        out_dir = os.path.join(RESULTS_DIR,"09_bracken","{sample}"),
        rank = lambda wildcards: '{}'.format(wildcards.rank)[:1].capitalize()

    shell:
        """
        mkdir -p {params.out_dir}

        apptainer exec \
            --bind {RESULTS_DIR}:{RESULTS_DIR} \
            --bind  /lunarc/nobackup/projects/snic2019-34-3/:/lunarc/nobackup/projects/snic2019-34-3/ \
            {params.bracken} bracken \
                -r {READ_LEN} \
                -i {input.kraken_report} \
                -o {output.bracken_report} \
                -d {params.database} \
                -l {params.rank} > {log.bracken_log} 2>&1
        """

# Step 11: Rule Standardize Bracken
rule standardize_bracken:
    input:
        bracken_report = os.path.join(RESULTS_DIR,"09_bracken","{sample}","{rank}.tsv")

    output:
        std_bracken_report = os.path.join(RESULTS_DIR,"10_standardized_bracken","{sample}_{rank}.csv")
    
    params:
        out_dir = os.path.join(RESULTS_DIR,"10_standardized_bracken"),
        min_abd = 0.001
    
    run:
        os.makedirs(str(params.out_dir), exist_ok=True)
        standardize_bracken(str(input.bracken_report),str(params.out_dir),float(params.min_abd))

# Step 12: Merge standardized Bracken reports by rank
rule merge_bracken:
    input:
        lambda wildcards: expand(os.path.join(RESULTS_DIR,"10_standardized_bracken","{sample}_{rank}.csv"), 
                                sample=SAMPLES, rank=wildcards.rank)
    output:
        merged_report = os.path.join(RESULTS_DIR,"11_final_reports","kraken_bracken_{rank}.csv")
    
    params:
        out_dir = os.path.join(RESULTS_DIR,"11_final_reports")
    
    run:
        os.makedirs(str(params.out_dir), exist_ok=True)
        concat_tables(list(input), str(output.merged_report))