# To run snakemake on a single node for 1-2 samples use the the slurms script /scripts/snakemake_slurm/slurm_snakemake_core-nt_process.sh
# To run snakemake on a small scale 5-20 samples use the following command
"""
screen -S snakemake
conda activate snakemake
snakemake --snakefile workflow/Snakefile --profile profiles/small_scale --configfile config/config_single_run.yaml 
    --config samples_file=/home/chandru/binp51/config/samples_test.tsv > logs/snakemake_update.log 2>&1

