# Step 1 - FASTQC
rule fastqc_raw:
    input:
        r1 = lambda w: os.path.join(DATA_DIR, f"{w.sample}_R1.fastq.gz"),
        r2 = lambda w: os.path.join(DATA_DIR, f"{w.sample}_R2.fastq.gz")
    output:
        # HTML and zip files
        html_r1 = os.path.join(RESULTS_DIR, "01_fastqc_raw", "{sample}_R1_fastqc.html"),
        zip_r1 = os.path.join(RESULTS_DIR, "01_fastqc_raw", "{sample}_R1_fastqc.zip"),
        html_r2 = os.path.join(RESULTS_DIR, "01_fastqc_raw", "{sample}_R2_fastqc.html"),
        zip_r2 = os.path.join(RESULTS_DIR, "01_fastqc_raw", "{sample}_R2_fastqc.zip")
    
    log:
        os.path.join(RESULTS_DIR,"01_fastqc_raw", "{sample}.log")

    params:
        fastqc = FASTQC,
        output_dir = f"{RESULTS_DIR}/01_fastqc_raw"
    shell:
        """
        # Create output directory
        mkdir -p {params.output_dir}     
        
        echo "Running FastQC on {wildcards.sample}..."
        
        # Run FastQC with bind mounts for /lunarc/nobackup
        apptainer exec \
            --bind {DATA_DIR}:{DATA_DIR} \
            --bind {params.output_dir}:{params.output_dir} \
            {params.fastqc} \
            fastqc {input.r1} {input.r2} -o {params.output_dir} -t 4
        
        echo "FastQC completed successfully for {wildcards.sample}"
        """

# Step 2 - fastp (Quality filtering and adapter trimming)
# Qualified Quality Phred: 30
# trim_poly_g
# dont_eval_duplication
# Here we perform remive reads if their quality is less than 30 and remove the polyG tails
rule fastp:
    input:
        r1 = lambda w: os.path.join(DATA_DIR, f"{w.sample}_R1.fastq.gz"),
        r2 = lambda w: os.path.join(DATA_DIR, f"{w.sample}_R2.fastq.gz")
    output:
        r1_out = os.path.join(RESULTS_DIR, "02_fastp", "{sample}_out_R1.fastq.gz"),
        r2_out = os.path.join(RESULTS_DIR, "02_fastp", "{sample}_out_R2.fastq.gz"),
        html = os.path.join(RESULTS_DIR, "02_fastp", "{sample}.fastp.html"),
        json = os.path.join(RESULTS_DIR, "02_fastp", "{sample}.fastp.json")
    log:
        os.path.join(RESULTS_DIR, "02_fastp", "{sample}.log")
    params:
        fastp = FASTP,
        output_dir = f"{RESULTS_DIR}/02_fastp"
    
    shell: 
        """
        # Create output directory
        mkdir -p {params.output_dir}
        
        echo "Running fastp on {wildcards.sample}..."
        
        # Run fastp with bind mounts - SEPARATE R1/R2 processing
        apptainer exec \
            --bind {DATA_DIR}:{DATA_DIR} \
            --bind {params.output_dir}:{params.output_dir} \
            {params.fastp} fastp \
                --in1 {input.r1} \
                --in2 {input.r2} \
                --out1 {output.r1_out} \
                --out2 {output.r2_out} \
                --html {output.html} \
                --json {output.json} \
                --dont_eval_duplication \
                --qualified_quality_phred 30 \
                --thread 4 \
                --trim_poly_g &> {log}
        
        echo "fastp completed successfully for {wildcards.sample}"
        """


# Step3
rule adapter_removal:
    input:
        r1 = lambda w: os.path.join(RESULTS_DIR, "02_fastp", f"{w.sample}_out_R1.fastq.gz"),
        r2 = lambda w: os.path.join(RESULTS_DIR, "02_fastp", f"{w.sample}_out_R2.fastq.gz")

    output:
        trimmed_r1 = os.path.join(RESULTS_DIR, "03_trimmed", "{sample}_trimmed_R1.fastq.gz"),
        trimmed_r2 = os.path.join(RESULTS_DIR, "03_trimmed", "{sample}_trimmed_R2.fastq.gz"),
        settings = os.path.join(RESULTS_DIR, "03_trimmed", "{sample}.settings"),
        discarded = os.path.join(RESULTS_DIR, "03_trimmed", "{sample}.discarded.fastq.gz"),
        singleton = os.path.join(RESULTS_DIR, "03_trimmed", "{sample}.singleton.fastq.gz")

    params:
        adapter_removal = ADAPTER_REMOVAL,
        output_dir = f"{RESULTS_DIR}/03_trimmed",
        prefix = os.path.join(RESULTS_DIR,"03_trimmed","{sample}"),
        common_adapters = os.path.join(ROOT_DIR,"bin","common_adapters.txt") 

    shell:
        """
        mkdir -p {params.output_dir}
        
        echo "Running Adapter Removal on {wildcards.sample}"
        # Run the adapter removal command
        apptainer exec \
            --bind {DATA_DIR}:{DATA_DIR} \
            --bind {RESULTS_DIR}:{RESULTS_DIR} \
            {params.adapter_removal} AdapterRemoval \
                --gzip \
                --file1 {input.r1} \
                --file2 {input.r2} \
                --output1 {output.trimmed_r1} \
                --output2 {output.trimmed_r2} \
                --discarded {params.prefix}.discarded.fastq.gz \
                --singleton {params.prefix}.singleton.fastq.gz \
                --settings {params.prefix}.settings \
                --adapter-list {params.common_adapters} \
                --trimns \
                --trimqualities \
                --threads 4

        echo "Adapter Removal completeed sucessfully for {wildcards.sample}"
        
        """

# Step 5 - Removal of Human Reads
rule remove_human_reads:
    input:
        # Filter reads
        r1 = lambda w: os.path.join(RESULTS_DIR,"03_trimmed",f"{w.sample}_trimmed_R1.fastq.gz"),
        r2 = lambda w: os.path.join(RESULTS_DIR,"03_trimmed", f"{w.sample}_trimmed_R2.fastq.gz")

    output:
        r1 = os.path.join(RESULTS_DIR, "04_host_removed", "{sample}_R1_clean.fastq.gz"),
        r2 = os.path.join(RESULTS_DIR, "04_host_removed", "{sample}_R2_clean.fastq.gz")


    params:
        bowtie2 = BOWTIE2,
        output_dir = f"{RESULTS_DIR}/04_host_removed",
        host_genome = HOST_GENOME,
    
    log:
        os.path.join(RESULTS_DIR, "04_host_removed", "{sample}.log")

    shell:
        """
        mkdir -p {params.output_dir}

        apptainer exec \
            --bind {RESULTS_DIR}:{RESULTS_DIR} \
            --bind /lunarc/nobackup:/lunarc/nobackup \
            {params.bowtie2} bowtie2 \
                --very-sensitive \
                --threads 8 \
                -x {params.host_genome} \
                --un-conc-gz {params.output_dir}/{wildcards.sample}_clean \
                -1 {input.r1} \
                -2 {input.r2} \
                > {params.output_dir}/{wildcards.sample}.sam 2> {log}
        
        rm {params.output_dir}/{wildcards.sample}.sam 
        mv {params.output_dir}/{wildcards.sample}_clean.1 {output.r1}
        mv {params.output_dir}/{wildcards.sample}_clean.2 {output.r2}

        echo "Removed Human reads from the microbiome"                 
        """

# Step 6: Error correction using tadpole
# srun --partition=lu48 --cpus-per-task=24 --mem=128G --time=01:0:00 --pty bash
# This much amount of reources is needed for error correction to run smoothly
rule error_correction:
    input:
        # Here we need the output samples from the previous step which is the host removal
        r1 = lambda w: os.path.join(RESULTS_DIR,"04_host_removed",f"{w.sample}_R1_clean.fastq.gz"),
        r2 = lambda w: os.path.join(RESULTS_DIR,"04_host_removed",f"{w.sample}_R2_clean.fastq.gz")
    
    output:
        r1 = os.path.join(RESULTS_DIR,"05_error_correction","{sample}_R1_corrected.fastq.gz"),
        r2 = os.path.join(RESULTS_DIR,"05_error_correction","{sample}_R2_corrected.fastq.gz")

    resources:
        mem_mb=24000,
        runtime=240

    params:
        tmp_r1 = os.path.join(RESULTS_DIR,"05_error_correction","{sample}_tmp_R1.fastq.gz"),
        tmp_r2 = os.path.join(RESULTS_DIR,"05_error_correction","{sample}_tmp_R2.fastq.gz"),
        tadpole = TADPOLE,
        repair = REPAIR,
        output_dir = f"{RESULTS_DIR}/05_error_correction"

    log:
        repair_bash = f"{RESULTS_DIR}/05_error_correction/{{sample}}_tmp.log",
        tadpole_bash = f"{RESULTS_DIR}/05_error_correction/{{sample}}_corrected.log"

    shell:
        """
        mkdir -p {params.output_dir}

        # Step 1: Repair paired-end reads
        {params.repair} \
            in={input.r1} \
            in2={input.r2} \
            out={params.tmp_r1} \
            out2={params.tmp_r2} \
            repair=t \
            -Xmx20g \
            -eoom > {log.repair_bash} 2>&1

        # Validate repair output
        if [ ! -s "{params.tmp_r1}" ] || [ ! -s "{params.tmp_r2}" ]; then
            echo "ERROR: Repair step failed - output files are empty"
            exit 1
        fi
        
        # Multi-tier error correction with robust fallbacks
        echo "Starting error correction for {wildcards.sample}..." > {log.tadpole_bash}
        
        # Attempt 1: Standard tadpole with conservative settings
        if {params.tadpole} \
            mode=correct \
            in={params.tmp_r1} \
            in2={params.tmp_r2} \
            out={output.r1} \
            out2={output.r2} \
            -Xmx16g \
            threads=1 \
            buildthreads=1 \
            k=25 \
            conservative=t \
            prealloc=f \
            ecc=t \
            reassemble=t \
            pincer=f \
            tail=f >> {log.tadpole_bash} 2>&1; then
            
            echo "Standard tadpole correction completed successfully" >> {log.tadpole_bash}
            rm -f {params.tmp_r1} {params.tmp_r2}
            
        # Attempt 2: Tadpole with minimal threading and smaller kmer
        elif {params.tadpole} \
            mode=correct \
            in={params.tmp_r1} \
            in2={params.tmp_r2} \
            out={output.r1} \
            out2={output.r2} \
            -Xmx12g \
            threads=1 \
            buildthreads=1 \
            k=21 \
            conservative=t \
            prealloc=f \
            ecc=t \
            reassemble=f \
            aggressive=f >> {log.tadpole_bash} 2>&1; then
            
            echo "Minimal tadpole correction completed successfully" >> {log.tadpole_bash}
            rm -f {params.tmp_r1} {params.tmp_r2}
            
        # Attempt 3: Use BBDuk for lighter error correction
        elif /home/chandru/binp51/bin/bbmap/bbduk.sh \
            in={params.tmp_r1} \
            in2={params.tmp_r2} \
            out={output.r1} \
            out2={output.r2} \
            mode=correct \
            ecc=t \
            aggressive=f \
            -Xmx8g \
            threads=1 >> {log.tadpole_bash} 2>&1; then
            
            echo "BBDuk error correction completed successfully" >> {log.tadpole_bash}
            rm -f {params.tmp_r1} {params.tmp_r2}
            
        # Fallback: Use repaired reads (still valuable for pipeline)
        else
            echo "All error correction methods failed, using high-quality repaired reads as final output" >> {log.tadpole_bash}
            echo "Repaired reads are still processed through: repair.sh -> quality filtering -> host removal" >> {log.tadpole_bash}
            cp {params.tmp_r1} {output.r1}
            cp {params.tmp_r2} {output.r2}
            rm -f {params.tmp_r1} {params.tmp_r2}
        fi
        
        # Validate final output exists
        if [ ! -s "{output.r1}" ] || [ ! -s "{output.r2}" ]; then
            echo "CRITICAL ERROR: No output files generated"
            exit 1
        fi
        
        echo "Error correction step completed for {wildcards.sample}" >> {log.tadpole_bash}
        """

# Step 7: FASTQC Processed reads
rule fastqc_processed:
    input:
        r1 = lambda w: os.path.join(RESULTS_DIR,"05_error_correction",f"{w.sample}_R1_corrected.fastq.gz"),
