configfile: "config/config.yaml"


import os
import sys
import subprocess
from pathlib import Path
from smk_helper.helper_scripts import load_sample_sheet, get_sample_names
from smk_helper.standardize_bracken import standardize_bracken, concat_tables
from smk_helper.select_partition import select_best_partition

ROOT_DIR = Path.cwd()

# Tool image directories
TOOLS = {k: f"{ROOT_DIR}/{v}" for k, v in config["tools"].items()}

# Dynamic sample sheet path via config
DEFAULT_SAMPLE_SHEET = config["samples"]["sample_sheet"]

# If passed via --config samples_file=path/to/samplesheet.tsv, use it
SAMPLE_SHEET = config.get("samples_file", DEFAULT_SAMPLE_SHEET)

print(f"[Snakefile] Using sample sheet: {SAMPLE_SHEET}", file=sys.stderr)

# Verify the file exists
if not Path(SAMPLE_SHEET).exists():
    raise FileNotFoundError(f"Sample sheet not found: {SAMPLE_SHEET}")

# Load samples from sheet
SAMPLE_DF = load_sample_sheet(SAMPLE_SHEET, max_samples=config["samples"]["max_samples"])

SAMPLES = get_sample_names(SAMPLE_DF)

print(f"[Snakefile] Loaded {len(SAMPLES)} sample(s): {SAMPLES}", file=sys.stderr)

# Samples folder for the Malmo samples
DATA_DIR = config["data"]["raw_dir"]
RESULTS_DIR = config["data"]["results_dir"]
READS = ["R1", "R2"]
RANKS = config["taxonomy"]["ranks"]

# Database paths
# Host Genome (Human - hG38)
HOST_GENOME = config["databases"]["human_genome"]
# Common Adapters
COMMON_ADAPTERS = f"{ROOT_DIR}/{config['databases']['common_adapters']}"
# Kraken2 and Bracken Database (core-nt - 307G)
KRAKEN2_DB = config["databases"]["kraken2_db"]
BRACKEN_DB = config["databases"]["kraken2_db"]
READ_LEN = config["samples"]["read_length"]

# Enable/disable pipeline steps
STEPS = config["pipeline"]["steps"]

# Dynamic target list
TARGETS = []


# Include common functions
include: "rules/common.smk"


if STEPS.get("fastqc_raw"):
    TARGETS.extend(
        expand(
            os.path.join(RESULTS_DIR, "01_fastqc_raw", "{sample}_{read}_fastqc.html"),
            sample=SAMPLES,
            read=READS,
        )
    )

if STEPS.get("fastqc_post"):
    TARGETS.extend(
        expand(
            os.path.join(RESULTS_DIR, "06_fastqc_post", "{sample}_{read}_corrected_fastqc.html"),
            sample=SAMPLES,
            read=READS,
        )
    )

if STEPS.get("multiqc"):
    TARGETS.append(os.path.join(RESULTS_DIR, "07_multiqc"))

if STEPS.get("merge_bracken"):
    TARGETS.extend(
        expand(
            os.path.join(RESULTS_DIR, "11_final_reports", "kraken_bracken_{rank}.csv"),
            rank=RANKS,
        )
    )

if STEPS.get("dnaberts_embeddings"):
    TARGETS.extend(
        expand(
            os.path.join(RESULTS_DIR, "12_dnaberts", "{sample}", "{sample}_embeddings.json"),
            sample=SAMPLES,
        )
    )


rule all:
    input:
        TARGETS


include: "rules/qc.smk"
include: "rules/preprocessing.smk"
include: "rules/classification.smk"
include: "rules/postprocessing.smk"
include: "rules/assembly.smk"
include: "rules/bert.smk"
