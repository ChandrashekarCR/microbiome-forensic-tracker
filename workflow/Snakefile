# Test scripts with few resources
#srun --partition=lu48 --cpus-per-task=6 --mem=16G --time=1:00:00 --pty bash

import os
import sys
from pathlib import Path

# Add the scripts directory to the Python path (absolute path)
sys.path.insert(0, os.path.join(workflow.basedir, "scripts"))

from helper_scripts import get_fastq_samples
ROOT_DIR = Path.cwd()

# Tool image directories
FASTQC = f"{ROOT_DIR}/bin/fastqc.sif"
FASTP = f"{ROOT_DIR}/bin/fastp.sif"
ADAPTER_REMOVAL = f"{ROOT_DIR}/bin/adapter_removal.sif"
MULTIQC = f"{ROOT_DIR}/bin/multiqc.sif"
BOWTIE2 = f"{ROOT_DIR}/bin/bowtie2.sif"
SAMTOOLS = f"{ROOT_DIR}/bin/samtools.sif"
REPAIR = f"{ROOT_DIR}/bin/bbmap/repair.sh"
TADPOLE = f"{ROOT_DIR}/bin/bbmap/tadpole.sh"
SPADES = f"{ROOT_DIR}/bin/spades.sif"

# Samples folder for the Malmo samples
DATA_DIR = "/lunarc/nobackup/projects/snic2019-34-3/shared_elhaik_lab1/Projects/Microbiome/Malmo2025/fastq_files"
RESULTS_DIR = "/home/chandru/binp51/results"
SAMPLES = get_fastq_samples(DATA_DIR, '_R1.fastq.gz','_R2.fastq.gz')[:3]
READS = ["R1","R2"] # Forward and reverse reads

# Host Genome (Human - hG38)
HOST_GENOME = "/lunarc/nobackup/projects/snic2019-34-3/Daria/CAMP/ref_Human_hg38/ref_Human_hg38/hg38_ref/hg38_index"

rule all:
    input:
        # FastQC reports
        expand(
            os.path.join(RESULTS_DIR, "01_fastqc_raw", "{sample}_{read}_fastqc.html"),
            sample = SAMPLES,
            read = READS
        ),
        # fastp outputs
        expand(
            os.path.join(RESULTS_DIR, "02_fastp", "{sample}_out_{read}.fastq.gz"),
            sample = SAMPLES,
            read = READS
        ),

        # Adaptor removal outputs
        expand(
            os.path.join(RESULTS_DIR, "03_trimmed","{sample}_trimmed_{read}.fastq.gz"),
            sample = SAMPLES,
            read = READS
        ),

        # Multiqc reports
        os.path.join(RESULTS_DIR,"04_multiqc/filter_reads_multiqc_report","multiqc_report.html"),

        # Removal of Host Genome
        expand(
            os.path.join(RESULTS_DIR,"05_host_removed","{sample}_{read}_clean.fastq.gz"),
            sample = SAMPLES,
            read = READS
        ),

        # Error correction
        expand(
            os.path.join(RESULTS_DIR,"06_error_correction","{sample}_{read}.fastq.00.0_0.cor.fastq.gz"),
            sample = SAMPLES,
            read = ["1", "2"]
        )

# Step 1 - FASTQC
rule fastqc_raw:
    input:
        r1 = lambda w: os.path.join(DATA_DIR, f"{w.sample}_R1.fastq.gz"),
        r2 = lambda w: os.path.join(DATA_DIR, f"{w.sample}_R2.fastq.gz")
    output:
        # HTML and zip files
        html_r1 = os.path.join(RESULTS_DIR, "01_fastqc_raw", "{sample}_R1_fastqc.html"),
        zip_r1 = os.path.join(RESULTS_DIR, "01_fastqc_raw", "{sample}_R1_fastqc.zip"),
        html_r2 = os.path.join(RESULTS_DIR, "01_fastqc_raw", "{sample}_R2_fastqc.html"),
        zip_r2 = os.path.join(RESULTS_DIR, "01_fastqc_raw", "{sample}_R2_fastqc.zip")
    
    log:
        os.path.join(RESULTS_DIR,"01_fastqc_raw", "{sample}.log")

    params:
        fastqc = FASTQC,
        output_dir = f"{RESULTS_DIR}/01_fastqc_raw"
    shell:
        """
        # Create output directory
        mkdir -p {params.output_dir}     
        
        echo "Running FastQC on {wildcards.sample}..."
        
        # Run FastQC with bind mounts for /lunarc/nobackup
        apptainer exec \
            --bind {DATA_DIR}:{DATA_DIR} \
            --bind {params.output_dir}:{params.output_dir} \
            {params.fastqc} \
            fastqc {input.r1} {input.r2} -o {params.output_dir} -t 4
        
        echo "FastQC completed successfully for {wildcards.sample}"
        """

# Step 2 - fastp (Quality filtering and adapter trimming)
# Qualified Quality Phred: 30
# trim_poly_g
# dont_eval_duplication
# Here we perform remive reads if their quality is less than 30 and remove the polyG tails
rule fastp:
    input:
        r1 = lambda w: os.path.join(DATA_DIR, f"{w.sample}_R1.fastq.gz"),
        r2 = lambda w: os.path.join(DATA_DIR, f"{w.sample}_R2.fastq.gz")
    output:
        r1_out = os.path.join(RESULTS_DIR, "02_fastp", "{sample}_out_R1.fastq.gz"),
        r2_out = os.path.join(RESULTS_DIR, "02_fastp", "{sample}_out_R2.fastq.gz"),
        html = os.path.join(RESULTS_DIR, "02_fastp", "{sample}.fastp.html"),
        json = os.path.join(RESULTS_DIR, "02_fastp", "{sample}.fastp.json")
    log:
        os.path.join(RESULTS_DIR, "02_fastp", "{sample}.log")
    params:
        fastp = FASTP,
        output_dir = f"{RESULTS_DIR}/02_fastp"
    
    shell: 
        """
        # Create output directory
        mkdir -p {params.output_dir}
        
        echo "Running fastp on {wildcards.sample}..."
        
        # Run fastp with bind mounts - SEPARATE R1/R2 processing
        apptainer exec \
            --bind {DATA_DIR}:{DATA_DIR} \
            --bind {params.output_dir}:{params.output_dir} \
            {params.fastp} fastp \
                --in1 {input.r1} \
                --in2 {input.r2} \
                --out1 {output.r1_out} \
                --out2 {output.r2_out} \
                --html {output.html} \
                --json {output.json} \
                --dont_eval_duplication \
                --qualified_quality_phred 30 \
                --thread 4 \
                --trim_poly_g &> {log}
        
        echo "fastp completed successfully for {wildcards.sample}"
        """


# Step3
rule adapter_removal:
    input:
        r1 = lambda w: os.path.join(RESULTS_DIR, "02_fastp", f"{w.sample}_out_R1.fastq.gz"),
        r2 = lambda w: os.path.join(RESULTS_DIR, "02_fastp", f"{w.sample}_out_R2.fastq.gz")

    output:
        trimmed_r1 = os.path.join(RESULTS_DIR, "03_trimmed", "{sample}_trimmed_R1.fastq.gz"),
        trimmed_r2 = os.path.join(RESULTS_DIR, "03_trimmed", "{sample}_trimmed_R2.fastq.gz")

    params:
        adapter_removal = ADAPTER_REMOVAL,
        output_dir = f"{RESULTS_DIR}/03_trimmed",
        prefix = os.path.join(RESULTS_DIR,"03_trimmed","{sample}"),
        common_adapters = os.path.join(ROOT_DIR,"bin","common_adapters.txt") 

    shell:
        """
        mkdir -p {params.output_dir}
        
        echo "Running Adapter Removal on {wildcards.sample}"
        # Run the adapter removal command
        apptainer exec \
            --bind {DATA_DIR}:{DATA_DIR} \
            --bind {RESULTS_DIR}:{RESULTS_DIR} \
            {params.adapter_removal} AdapterRemoval \
                --gzip \
                --file1 {input.r1} \
                --file2 {input.r2} \
                --output1 {output.trimmed_r1} \
                --output2 {output.trimmed_r2} \
                --discarded {params.prefix}.discarded.fastq.gz \
                --singleton {params.prefix}.singleton.fastq.gz \
                --settings {params.prefix}.settings \
                --adapter-list {params.common_adapters} \
                --trimns \
                --trimqualities \
                --threads 4

        echo "Adapter Removal completeed sucessfully for {wildcards.sample}"
        
        """

# Step4 - MultiQC
rule multiqc:
    input:
        # Raw fastqc, fastp, adapter removal
        raw_fastqc_results = os.path.join(RESULTS_DIR, "01_fastqc_raw"),
        fastp_results = os.path.join(RESULTS_DIR, "02_fastp"),
        adapter_removal_results = os.path.join(RESULTS_DIR, "03_trimmed")
    
    output:
        multiqc_report = directory(
            os.path.join(RESULTS_DIR,"04_multiqc/filter_reads_multiqc_report")
        )
    
    params:
        multiqc = MULTIQC,
        output_dir = f"{RESULTS_DIR}/04_multiqc"

    shell:
        """
        mkdir -p {params.output_dir}

        apptainer exec \
            --bind {DATA_DIR}:{DATA_DIR} \
            --bind {RESULTS_DIR}:{RESULTS_DIR} \
            {params.multiqc} multiqc \
                {input.raw_fastqc_results} {input.fastp_results} {input.adapter_removal_results} \
                -o {output.multiqc_report}

        """

# Step 5 - Removal of Human Reads
rule remove_human_reads:
    input:
        # Filter reads
        r1 = lambda w: os.path.join(RESULTS_DIR,"03_trimmed",f"{w.sample}_trimmed_R1.fastq.gz"),
        r2 = lambda w: os.path.join(RESULTS_DIR,"03_trimmed", f"{w.sample}_trimmed_R2.fastq.gz")

    output:
        r1 = os.path.join(RESULTS_DIR, "05_host_removed", "{sample}_R1_clean.fastq.gz"),
        r2 = os.path.join(RESULTS_DIR, "05_host_removed", "{sample}_R2_clean.fastq.gz")


    params:
        bowtie2 = BOWTIE2,
        output_dir = f"{RESULTS_DIR}/05_host_removed",
        host_genome = HOST_GENOME,
    
    log:
        os.path.join(RESULTS_DIR, "05_host_removed", "{sample}.log")

    shell:
        """
        mkdir -p {params.output_dir}

        apptainer exec \
            --bind {RESULTS_DIR}:{RESULTS_DIR} \
            --bind /lunarc/nobackup:/lunarc/nobackup \
            {params.bowtie2} bowtie2 \
                --very-sensitive \
                --threads 8 \
                -x {params.host_genome} \
                --un-conc-gz {params.output_dir}/{wildcards.sample}_clean \
                -1 {input.r1} \
                -2 {input.r2} \
                > {params.output_dir}/{wildcards.sample}.sam 2> {log}
        
        rm {params.output_dir}/{wildcards.sample}.sam 
        mv {params.output_dir}/{wildcards.sample}_clean.1 {output.r1}
        mv {params.output_dir}/{wildcards.sample}_clean.2 {output.r2}

        echo "Removed Human reads from the microbiome"                 
        """

# Step 6: Error correction using tadpole
rule error_correction:
    input:
        # Here we need the output samples from the previous step which is the host removal
        r1 = lambda w: os.path.join(RESULTS_DIR,"05_host_removed",f"{w.sample}_R1_clean.fastq.gz"),
        r2 = lambda w: os.path.join(RESULTS_DIR,"05_host_removed",f"{w.sample}_R2_clean.fastq.gz")
    
    output:
        r1 = os.path.join(RESULTS_DIR,"06_error_correction","{sample}_1.fastq.00.0_0.cor.fastq.gz"),
        r2 = os.path.join(RESULTS_DIR,"06_error_correction","{sample}_2.fastq.00.0_0.cor.fastq.gz")

    params:
        spades = SPADES,
        sample_output_dir = f"{RESULTS_DIR}/06_error_correction/{{sample}}_spades_temp"

    log:
        spades_log = f"{RESULTS_DIR}/06_error_correction/{{sample}}.log"

    shell:
        """
        # Create clean output directory for this sample
        rm -rf {params.sample_output_dir}
        mkdir -p {params.sample_output_dir}

        # Run SPAdes error correction with correct parameter name
        apptainer exec \
            --bind {RESULTS_DIR}:{RESULTS_DIR} \
            {params.spades} spades.py \
                --only-error-correction \
                --meta \
                -t 4 \
                -m 12000 \
                -1 {input.r1} \
                -2 {input.r2} \
                -o {params.sample_output_dir} > {log.spades_log} 2>&1
        
        # Move the corrected files to expected output locations
        mv {params.sample_output_dir}/corrected/*_1.fastq.00.0_0.cor.fastq.gz {output.r1}
        mv {params.sample_output_dir}/corrected/*_2.fastq.00.0_0.cor.fastq.gz {output.r2}
        
        # Clean up temporary directory
        rm -rf {params.sample_output_dir}
        """