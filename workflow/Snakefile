        expand(os.path.join(RESULTS_DIR, "05_error_correction", "{sample}_corrected.log"), sample=SAMPLES),
        expand(os.path.join(RESULTS_DIR, "06_fastqc_post", "{sample}_{read}_corrected_fastqc.html"), sample=SAMPLES, read=READS)
    
    output:
